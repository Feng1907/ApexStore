generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String
  brand       String           @default("Apple")
  category    Category
  basePrice   Decimal          @db.Decimal(12, 0)
  images      String[]
  featured    Boolean          @default(false)
  variants    ProductVariant[]
  reviews     Review[]
  knowledge   AIKnowledge[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([category])
  @@index([slug])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  storage    String
  color      String
  colorHex   String
  price      Decimal     @db.Decimal(12, 0)
  stock      Int         @default(0)
  sku        String      @unique
  orderItems OrderItem[]
  flashSales FlashSale[]

  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  items         OrderItem[]
  status        OrderStatus @default(PENDING)
  totalAmount   Decimal     @db.Decimal(12, 0)
  shippingAddr  Json
  paymentMethod String
  paymentRef    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id])
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal        @db.Decimal(12, 0)
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  userId    String
  userName  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  @@index([productId])
}

model FlashSale {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  discount  Float
  stock     Int
  startAt   DateTime
  endAt     DateTime
  active    Boolean        @default(true)
}

model AIKnowledge {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  content   String
}

enum Category {
  IPHONE
  IPAD
  MACBOOK
  AIRPODS
  APPLE_WATCH
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}
